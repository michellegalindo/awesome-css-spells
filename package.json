{
  "name": "awesome-css",
  "version": "0.1.0",
  "description": "A curated list of awesome CSS resources",
  "scripts": {
    "add-resource": "tsx scripts/add-resource/add_readme_resource.ts",
    "start": "npx serve .",
    "format": "prettier --write \"**/*.{js,ts,html,css}\"",
    "format:check": "prettier --check \"**/*.{js,ts,html,css}\"",
    "test": "tsx --test scripts/**/*.test.ts assets/**/*.test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/michellegalindo/awesome-css.git"
  },
  "author": "Michelle Galindo",
  "license": "MIT",
  "prettier": {
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3"
  }
}
